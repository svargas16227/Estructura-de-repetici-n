Algoritmo hagaMientrasque
	Definir clave Como Cadena

    Repetir
        
        Escribir "Ingrese la contraseńa:"
        Leer clave
        
        Si clave <> "1234" Entonces
            Escribir "Contraseńa incorrecta"
        FinSi
        
    Hasta Que clave = "1234"
	
    Escribir "Acceso permitido"

FinAlgoritmo
